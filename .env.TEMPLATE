# Claude Code Web Bridge Configuration
#
# RECOMMENDED: Use environment variables instead of this file.
# The setup script (setup.sh / setup.ps1) configures these automatically.
# This .env file is only needed if you prefer file-based config over env vars.
#
# Environment variables take priority over values in this file.

# Default working directory for new chats (defaults to where you run the server)
# CLAUDE_WORKING_DIR=C:\projects\my-app

# Port the web server listens on (default: 3847)
# BRIDGE_PORT=3847

# Explicit path to claude binary (auto-discovered by default)
# CLAUDE_PATH=C:\Users\<you>\.claude\local\claude.exe

# Teams Outgoing Webhook — paste the HMAC secret from Teams here
# TEAMS_WEBHOOK_SECRET=

# Teams Incoming Webhook (via Workflow) — for posting long responses back to channel
# TEAMS_INCOMING_WEBHOOK_URL=

# Web Push VAPID keys (auto-generated by setup script)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Claude Code CLI notification hook — webhook URL for Teams notifications
# CLAUDE_TEAMS_WEBHOOK_URL=
